# Auto detect text files and perform LF normalization
* text=auto

# Force LF for source files
*.py text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.xsd text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sh text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.whl binary
*.gz binary
*.zip binary
*.tar binary
*.db binary
*.sqlite binary
*.parquet binary
